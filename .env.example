# Copy to .env (gitignored). In the cluster these come from External Secrets.

# --- server (defaults shown; usually no need to change) ---
PORT=8080
REPOS_DIR=/data/repos
SESSIONS_DIR=/data/sessions

# --- agent credentials: consumed by the CLIs inside tmux, never by the backend ---
# Claude: generate with `claude setup-token` on a machine with a browser (valid ~1 year).
# NEVER set ANTHROPIC_API_KEY here: it silently overrides Max-plan auth and bills per token.
CLAUDE_CODE_OAUTH_TOKEN=

# Antigravity (agy): API key for headless auth. Alternatively run `agy` once
# interactively in the pod terminal; the OAuth token persists in $HOME on the PVC.
ANTIGRAVITY_API_KEY=

# Codex: API-billed. For ChatGPT-plan auth instead, run `codex login` once in the pod.
OPENAI_API_KEY=

# GitHub: used by gh (clone) and git push.
GH_TOKEN=

# Git author for commits made in session terminals (git reads these natively;
# no gitconfig needed). Committer should normally match author.
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
GIT_COMMITTER_NAME=
GIT_COMMITTER_EMAIL=
